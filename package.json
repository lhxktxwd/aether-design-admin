{
  "name": "aether-design-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "typecheck": "vue-tsc -b",
    "create:local": "node packages/create-aether-admin/bin/create-aether-admin.js",
    "pack:cli": "pnpm --filter create-aether-admin pack:check",
    "release:cli:check-auth": "npm whoami --registry https://registry.npmjs.org/",
    "release:cli:latest": "pnpm release:cli:check-auth && pnpm pack:cli && pnpm --filter create-aether-admin publish:latest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "element-plus": "^2.10.4",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "~5.7.2",
    "unocss": "^66.7.2",
    "vite": "^8.1.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.10.0"
}
