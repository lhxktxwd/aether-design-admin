{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2022": true,
    "node": true,
    "vue": true
  },
  "plugins": ["typescript", "unicorn", "oxc", "vue"],
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "packages/create-aether-admin/.npm-cache/**",
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "rules": {
    "eqeqeq": "warn",
    "no-console": "warn",
    "no-debugger": "error",
    "vue/no-side-effects-in-computed-properties": "error",
    "vue/no-watch-after-await": "error",
    "vue/no-lifecycle-after-await": "error"
  },
  "overrides": [
    {
      "files": ["vite.config.ts", "uno.config.ts", "packages/create-aether-admin/bin/**/*.js"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
